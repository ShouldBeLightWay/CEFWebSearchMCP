CompileFlags:
  # CEF headers use GNU zero-variadic macros; under Clang+Werror this aborts
  # parsing with fatal_too_many_errors and cascades into fake include failures.
  Add:
    - -Wno-gnu-zero-variadic-macro-arguments

  # -Werror is for the real g++ build; clangd should not treat CEF pedantic
  # warnings as fatal parse errors.
  Remove:
    - -Werror
