{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "gcc-debug",
      "displayName": "GCC Debug (Linux)",
      "description": "Recommended preset on Ubuntu Linux while Clang toolchain issues are being investigated.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-gcc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "gcc-debug",
      "displayName": "Build GCC Debug",
      "configurePreset": "gcc-debug",
      "jobs": 4
    }
  ],
  "testPresets": [
    {
      "name": "gcc-debug",
      "displayName": "Test GCC Debug",
      "configurePreset": "gcc-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
